*.sqlite
*.db
*.sqlite3

# Weight/topology analysis caches
weight_graph/cache_*.pkl
*.pkl

# Externalized artifacts — large model files and caches moved out of git tracking
artifacts/

# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg

# Test artifacts
topomem/benchmarks/results/*.json
.pytest_cache/

